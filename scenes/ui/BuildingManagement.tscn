autowrap_mode = 2

[node name="ProdLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "production info"

[node name="UpgradeButton" type="Button" parent="Panel/VBoxContainer"]
custom_minimum_size = Vector2(0, 50)
layout_mode = 2
