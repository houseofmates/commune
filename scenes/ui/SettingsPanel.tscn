[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/SettingsPanel.gd" id="1_script"]

[node name="SettingsPanel" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="Panel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -200.0
offset_right = 150.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "settings"
horizontal_alignment = 1

[node name="MasterLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "master volume"

[node name="MasterSlider" type="HSlider" parent="Panel/VBox"]
layout_mode = 2
max_value = 1.0
step = 0.01

[node name="SFXLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "sfx volume"

[node name="SFXSlider" type="HSlider" parent="Panel/VBox"]
layout_mode = 2
max_value = 1.0
step = 0.01

[node name="MusicLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "music volume"

[node name="MusicSlider" type="HSlider" parent="Panel/VBox"]
layout_mode = 2
max_value = 1.0
step = 0.01

[node name="EraseButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "erase save data"

[node name="CloseButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "close"

[connection signal="value_changed" from="Panel/VBox/MasterSlider" to="." method="_on_master_slider_changed"]
[connection signal="value_changed" from="Panel/VBox/SFXSlider" to="." method="_on_sfx_slider_changed"]
[connection signal="value_changed" from="Panel/VBox/MusicSlider" to="." method="_on_music_slider_changed"]
[connection signal="pressed" from="Panel/VBox/EraseButton" to="." method="_on_erase_save_pressed"]
[connection signal="pressed" from="Panel/VBox/CloseButton" to="." method="_on_close_pressed"]
